# Telegram Bot Token from BotFather
TELEGRAM_BOT_TOKEN=your_botfather_token_here

# Ethereum & Solana RPC endpoints
ETHEREUM_RPC=https://mainnet.infura.io/v3/your_project_id
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Optional database URL (Postgres, SQLite, etc.)
# For SQLite (local testing) use: sqlite:///chainpilot.db
DATABASE_URL=sqlite:///chainpilot.db

# Webhook URL (needed when setting up)
WEBHOOK_URL=https://your-app-name.onrender.com/telegram/webhook