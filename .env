# Telegram bot token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Ethereum wallet address
ETH_WALLET_ADDRESS=your_eth_wallet_here

# Solana wallet address
SOL_WALLET_ADDRESS=your_solana_wallet_here

# Optional: Infura or Alchemy API for Ethereum
ETH_NODE_URL=https://mainnet.infura.io/v3/your_project_id

# Optional: Solana RPC URL
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com